	-- reduce the player below this HP. Per LOC_01 В§3 the clamp is BAYOU-WIDE (every huntable, incl. the
	-- aggressive gator), so an armorless EHT-1 player is mechanically safe вҖ” onboarding never stalls on death.
	nonLethalMinHP = 1,
	nonLethalDestinations = table.freeze({ bayou = true } :: { [string]: boolean }), -- whole T1 roster non-lethal (LOC В§3)
	-- В§6 co-op: sublinear Health vs linear DPS. partyCap bounds the scaling.
	coop = table.freeze({ hCoop = 0.5, partyCap = 4 }),
	-- В§2 range falloff: in-band вҶ’ 1.0; beyond optimal up to optimalВ·falloffExtension вҶ’ linear to floor;
	-- past that вҶ’ out of range (damage 0, the shot is rejected). (rangeBase/rangePerTier/floor in В§1.3.)
	range = table.freeze({ falloffExtension = 1.5 }),
	-- В§build-notes anti-exploit tolerances (rounding/latency slack; the server is still authoritative).
	fireRateToleranceSeconds = 0.05,
	damageToleranceAbs = 1,
	-- В§5 engagement-rate components per tier (co-owned with SYS_economy; the drift-prone input). Bayou T1
	-- вҶ’ TimePerTarget ~45 s вҶ’ ~80/hr, matching the combat В§5 table.
	engagement = table.freeze({
		[1] = table.freeze({ timeToFind = 25, timeToKill = 10, overhead = 10 }),
		[2] = table.freeze({ timeToFind = 45, timeToKill = 20, overhead = 15 }),
		[4] = table.freeze({ timeToFind = 75, timeToKill = 35, overhead = 20 }),
	}),
	-- SYS_progression В§4 Rank XP вҖ” difficulty/rarity-WEIGHTED (a Mythic вү« a Common; apex > floor). The
	-- WEIGHTING is the design; the magnitudes are tuning. Rank grants identity/convenience only (never power).
	rankXP = table.freeze({
		base = 10,
		tierStep = 0.5, -- +tierStep per tier above 1 (apex tiers are worth more)
		rarityWeight = table.freeze({ Common = 1, Uncommon = 1.5, Rare = 3, Epic = 6, Legendary = 12, Mythic = 25 } :: { [string]: number }),
		archetypeWeight = table.freeze({ passive = 1, flees = 1, aggressive = 1.5, pack = 1.75, ambush = 2 } :: { [string]: number }),
	}),
	-- Game-FEEL knobs вҖ” Studio/playtest, NOT headless. Captured so they are config, not code, when tuned.
	settleTimeSecondsByTier = table.freeze({ [1] = 0.6, [2] = 0.55, [3] = 0.5, [4] = 0.45 }), -- TODO(step-4 Studio feel)
	aimAssist = table.freeze({ strength = 0.5, coneDegrees = 6, capStrength = 0.7 }), -- TODO(Studio + platform-split telemetry)
})

-- В§fishing (Step 5) вҖ” the fishing-OWNED knobs (SYS_fishing В§5 engagement + В§4 Angler XP weighting). The
-- В§1/В§2 fishing CURVES live in offensive (R1), defensive (rod Pressure), and fishingFight above; this is
