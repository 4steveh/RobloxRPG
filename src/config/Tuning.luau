--!strict
-- THE MASTER TUNING CONSTANTS вҖ” the entire EQUIPMENT_MASTER В§1 set, plus the economy/progression
-- knobs the corpus enumerates. DATA ONLY in Step 1: the curves/resolution math that consume these
-- (WeaponDamage, ReelDrainMax, BreakThreshold, DR, Income, GearCost, Payout, FightTimeвҖҰ) are owned by
-- combat/fishing/economy and implemented in Steps 4вҖ“6. Captured here so Tier 9+ and retunes are config,
-- not code. Every magnitude is an illustrative default (a calibration knob), per the SYS_ docs.

local Tuning = {}

-- В§1.1 Shared difficulty constant Оә (combat + fishing, RD-F). Sets how fast Ceiling(T)вҲ’Floor(T) widens.
-- Realized as a geometric base (offensive curves) and an additive step (defensive/Pressure curve).
-- Owned JOINTLY with combat/fishing вҖ” do not change here unilaterally.
Tuning.spread = table.freeze({
	rho = 1.4, -- ПҒ вҖ” geometric base for offensive curves (the offensive face of Оә)
	pStep = 22, -- P_step вҖ” additive step for the defensive/Pressure curve (the defensive face of Оә)
})

-- В§1.2 Offensive curves вҖ” weapon (hunting) and reel (fishing). Reel mirrors weapon by construction,
-- which is WHY hunting and fishing income scale identically (dual-loop balance is structural).
--   WeaponDamage(T,в„“) = round(D1 В· ПҒ^(TвҲ’1) В· q(в„“));  ReelDrainMax(T,в„“) = round(R1 В· ПҒ^(TвҲ’1) В· q(в„“))
Tuning.offensive = table.freeze({
	D1 = 18, -- weapon damage base (Tier-1 mid)
	R1 = 9, -- reel drain base (Tier-1 mid)
	rho = 1.4, -- shared geometric base (= spread.rho)
	q = table.freeze({ entry = 0.78, mid = 1.0, maxed = 1.28 }), -- intra-tier floorвҶ’apex spread вүҲ 1.6Г—
})

-- В§1.3 Weapon cycle/range вҖ” set TimeToKill and TimeToFind.
--   CycleTime: T1 1.50 В· T2 1.40 В· T3 1.30 В· T4 1.25 В· then вҲ’0.04/tier, floor 1.0
--   Range(T) = rangeBase + rangePerTierВ·(TвҲ’1);  RangeFalloff = inBand within band, вҶ’ floor beyond.
Tuning.weapon = table.freeze({
	cycleTime = table.freeze({ [1] = 1.5, [2] = 1.4, [3] = 1.3, [4] = 1.25 }), -- explicit MVL tiers
	cycleTimeAnchorTier = 4, -- beyond this, CycleTime = cycleTime[4] вҲ’ perTierDecrementВ·(TвҲ’4)
	cycleTimePerTierDecrement = 0.04,
	cycleTimeFloor = 1.0,
	rangeBase = 36,
	rangePerTier = 12,
	rangeFalloffInBand = 1.0,
	rangeFalloffFloor = 0.4,
	-- SettleTime is per-weapon/tunable (no В§1 default) вҖ” owned by combat (Step 4). TODO(step-4).
})

-- В§1.4 Defensive curves вҖ” armor (hunting) and rod Pressure (fishing).
-- ARMOR HAS NO ITEM-STAT CURVE: its only gating attribute is `tier`; DR is DERIVED by combat from the
-- tier gap and the CREATURE's tier вҖ” not a stored item stat. Template-B "Protection 1вҖ“100" is display only.
--   DR = clamp(drBase + drStepВ·(armorTier вҲ’ creatureTier), drMin, drCap)
--   BreakThreshold(T,в„“) = round((P1 + P_stepВ·(TвҲ’1)) В· pq(в„“));  LandWindow = wВ·max(BreakThresholdвҲ’PeakRunForce,0)В·dragSmooth
Tuning.defensive = table.freeze({
	drBase = 0.50, -- DR at tier parity (armorTier == creatureTier)
	drStep = 0.12, -- DR change per tier of gap
	drMin = 0.0,
	drCap = 0.85, -- hard cap вҖ” why defense is bounded and apex "behaves-as-+1-tier"
	rodP1 = 30, -- rod BreakThreshold base
	rodPStep = 22, -- additive step (= spread.pStep)
	rodPq = table.freeze({ entry = 0.90, mid = 1.0, maxed = 1.12 }),
	landWindowW = 1.0, -- w in the LandWindow formula
})

-- В§1.5 Fishing fight constants (consumed by FightTime вүӨ LandWindow).
--   StaminaToLand = k_s В· FightDifficulty В· (1 + weight/W_ref)
--   NetDrain = ReelDrainMax В· E_expected вҲ’ FishRecovery;  FishRecovery = r В· FightDifficulty
--   PeakRunForce = p В· FightDifficulty
Tuning.fishingFight = table.freeze({
	k_s = 0.5,
	W_ref = 10, -- kg
	r = 0.08, -- FishRecovery coefficient
	p = 0.6, -- PeakRunForce coefficient
	E_expected = 0.7, -- tension-efficiency reference (fishing analog of Z_expected)
	dragSmooth = 1.0, -- В§2 LandWindow reel factor; flat at MVL (reel-scaling deferred), a tuning knob (Step 5)
})

